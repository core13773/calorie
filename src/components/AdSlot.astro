---
// Env-gated ad unit. Renders a real AdSense <ins> when PUBLIC_ADSENSE_CLIENT is set,
// otherwise a labeled placeholder (no external requests). Mirrors fincalc's AdSlot.
const client = import.meta.env.PUBLIC_ADSENSE_CLIENT as string | undefined;
interface Props { slot?: string; responsive?: boolean }
const { slot = '', responsive = true } = Astro.props;
---
{client ? (
  <div class="adwrap">
    <ins class="adsbygoogle" style="display:block" data-ad-client={client} data-ad-slot={slot} data-ad-format="auto" data-full-width-responsive={responsive ? 'true' : 'false'}></ins>
    <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>
) : (
  <div class="adwrap placeholder" aria-hidden="true">Advertisement · 광고</div>
)}
<style>
  .adwrap { margin: 1.75rem 0; min-height: 96px; display: grid; place-items: center; }
  .adwrap.placeholder { border: 1px dashed #e2e2e2; color: #bbb; font-size: .78rem; border-radius: 10px; background: #fafafa; }
</style>
