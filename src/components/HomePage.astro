---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import { getStats, getSampleFoods } from '../lib/db';

interface Props { lang: Lang }
const { lang } = Astro.props;
const s = t(lang);
const stats = await getStats();
let sample: Awaited<ReturnType<typeof getSampleFoods>> = [];
if (stats.configured && stats.foodCount > 0) {
  try { sample = await getSampleFoods(12, lang); } catch { sample = []; }
}
const foodPrefix = lang === 'ko' ? '/food' : '/en/food';
const searchPath = lang === 'ko' ? '/search' : '/en/search';
const catPath = lang === 'ko' ? '/category' : '/en/category';
const intro = lang === 'ko'
  ? '음식별 칼로리, 단백질, 탄수화물, 지방 등 영양성분을 100g 기준으로 확인하세요.'
  : 'Look up calories, protein, carbs, fat and more per 100g for thousands of foods.';
---
<section class="home-hero">
  <h1>🥗 {s.tagline}</h1>
  <p class="lead">{intro}</p>
  <form action={searchPath} method="get" role="search" class="searchbar">
    <input type="search" name="q" placeholder={s.searchPlaceholder} aria-label={s.search} autocomplete="off" />
    <button class="btn btn-primary" type="submit"><span aria-hidden="true">🔍</span><span class="btn-label">{s.search}</span></button>
  </form>
  {stats.configured && stats.foodCount > 0 && (
    <p class="pill stat-pill">✅ {lang === 'ko' ? '등록된 식품 ' : ''}<strong>{stats.foodCount.toLocaleString()}</strong>{lang === 'ko' ? '개' : ' foods'}</p>
  )}
</section>

{sample.length > 0 && (
  <section>
    <h2>{s.popularFoods}</h2>
    <ul class="grid-foods">
      {sample.map((f) => {
        const name = (lang === 'ko' ? (f.name_ko ?? f.name_en) : (f.name_en ?? f.name_ko)) ?? f.slug;
        return (
          <li>
            <a class="card card-hover food-card" href={`${foodPrefix}/${f.slug}`}>
              <span class="food-emoji">{f.emoji ?? '🍽️'}</span>
              <span class="food-name">{name}</span>
              {f.kcal != null && <span class="food-kcal">{f.kcal} kcal</span>}
            </a>
          </li>
        );
      })}
    </ul>
    <p class="more"><a class="btn" href={catPath}>📂 {lang === 'ko' ? '모든 카테고리 보기' : 'Browse all categories'} →</a></p>
  </section>
)}
<style>
  .home-hero { text-align: center; padding: 1.5rem 0 2rem; }
  .lead { color: var(--muted); max-width: 540px; margin: .5rem auto 1.3rem; }
  .searchbar { display: flex; gap: .5rem; max-width: 560px; margin: 0 auto 1rem; }
  .searchbar input { flex: 1; min-height: 48px; padding: .7rem 1rem; border: 1px solid var(--border); border-radius: 12px; font-size: 1.05rem; background: #fff; }
  .searchbar input:focus { outline: 2px solid var(--primary); outline-offset: -1px; border-color: var(--primary); }
  .stat-pill { margin-top: .8rem; }
  .food-card { display: flex; flex-direction: column; gap: .25rem; height: 100%; color: var(--text); }
  .food-card:hover { color: var(--text); }
  .food-emoji { font-size: 1.4rem; }
  .food-name { font-weight: 600; font-size: .95rem; line-height: 1.3; }
  .food-kcal { color: var(--primary-dark); font-size: .82rem; font-weight: 600; }
  .more { margin-top: 1.2rem; text-align: center; }
  @media (max-width: 560px) {
    .btn-label { display: none; }
    .home-hero { padding: 1rem 0 1.5rem; }
  }
</style>
