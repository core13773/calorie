---
import type { Lang } from '../i18n/ui';
import { t } from '../i18n/ui';
import { getNutrientMeta, type FoodDetail } from '../lib/db';
import { SOURCES, SITE_URL } from '../consts';
import AdSlot from './AdSlot.astro';

interface Props { food: FoodDetail; lang: Lang }
const { food, lang } = Astro.props;
const s = t(lang);

// Source attribution per-food (license requirement): USDA for English foods,
// 식약처 for Korean foods. Falls back to USDA if the source column is unset.
const src = food.source === 'mfds' ? SOURCES.mfds : SOURCES.usda;

const meta = await getNutrientMeta();

// nutrient display order: macros first, then minerals, then vitamins
const ORDER = ['energy','protein','fat','satFat','carb','sugars','fiber','cholesterol','calcium','iron','magnesium','phosphorus','potassium','sodium','zinc','vitA','vitC','vitE','vitB6','folate'];

const val = (id: string): number | null => food.nutrients.find((n) => n.nutrient_id === id)?.amount ?? null;
const kcal = val('energy');
const protein = val('protein');
const fat = val('fat');
const carb = val('carb');

// macro energy contribution %
let pPct = 33, fPct = 33, cPct = 34;
const pE = (protein ?? 0) * 4, fE = (fat ?? 0) * 9, cE = (carb ?? 0) * 4;
const tot = pE + fE + cE;
if (tot > 0) { pPct = Math.round(pE / tot * 100); fPct = Math.round(fE / tot * 100); cPct = Math.max(0, 100 - pPct - fPct); }

const rows = ORDER
  .map((id) => {
    const m = meta.get(id);
    const nrow = food.nutrients.find((x) => x.nutrient_id === id);
    return { id, label: m ? (lang === 'ko' ? (m.name_ko ?? m.name_en) : (m.name_en ?? m.name_ko)) : id, unit: nrow?.unit ?? '', value: nrow?.amount ?? null };
  })
  .filter((r) => r.value != null);

const foodName = (lang === 'ko' ? (food.name_ko ?? food.name_en) : (food.name_en ?? food.name_ko)) ?? food.slug;
const desc = (lang === 'ko' ? (food.desc_ko ?? food.desc_en) : (food.desc_en ?? food.desc_ko)) ?? '';

const tagLabel: Record<string, { ko: string; en: string }> = {
  'high-protein': { ko: '고단백', en: 'High protein' },
  'low-calorie': { ko: '저칼로리', en: 'Low calorie' },
  'low-fat': { ko: '저지방', en: 'Low fat' },
  'high-fiber': { ko: '고식이섬유', en: 'High fiber' },
  'high-sugar': { ko: '고당류', en: 'High sugar' },
  'high-sodium': { ko: '고나트륨', en: 'High sodium' },
  'lean-protein': { ko: '저지방 단백질', en: 'Lean protein' },
};

const faqs = [
  {
    q: lang === 'ko' ? `${foodName} 100g의 칼로리는?` : `How many calories are in ${foodName} per 100g?`,
    a: lang === 'ko' ? `${foodName}은(는) 100g당 ${kcal ?? '—'} kcal입니다.` : `${foodName} provides ${kcal ?? '—'} calories per 100 grams.`,
  },
  {
    q: lang === 'ko' ? `${foodName}의 단백질 함량은?` : `How much protein is in ${foodName}?`,
    a: lang === 'ko' ? `${foodName} 100g당 단백질은 ${protein ?? '—'}g입니다.` : `${foodName} contains ${protein ?? '—'}g of protein per 100g.`,
  },
  {
    q: lang === 'ko' ? `${foodName}의 주요 영양소 비율은?` : `What is the macronutrient ratio of ${foodName}?`,
    a: lang === 'ko' ? `100g 기준 에너지 기여도는 단백질 ${pPct}%, 지방 ${fPct}%, 탄수화물 ${cPct}%입니다.` : `By energy contribution per 100g: protein ${pPct}%, fat ${fPct}%, carbohydrates ${cPct}%.`,
  },
];

const pathPrefix = lang === 'ko' ? '/food' : '/en/food';
const pageUrl = `${SITE_URL}${lang === 'ko' ? '' : '/en'}/food/${food.slug}`;

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};

// BreadcrumbList + NutritionInformation structured data (rich results).
const crumb = [
  { name: lang === 'ko' ? '홈' : 'Home', url: `${SITE_URL}${lang === 'ko' ? '' : '/en'}` },
  ...(food.category ? [{ name: (lang === 'ko' ? (food.category.name_ko ?? food.category.name_en) : (food.category.name_en ?? food.category.name_ko)) ?? food.category.slug, url: `${SITE_URL}${lang === 'ko' ? '' : '/en'}/category/${food.category.slug}` }] : []),
  { name: foodName, url: pageUrl },
];
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumb.map((c, i) => ({ '@type': 'ListItem', position: i + 1, name: c.name, item: c.url })),
};
const ni = (amount: number | null, unit: string, key: string) =>
  amount == null ? {} : { [key]: `${amount} ${unit}` };
const nutritionLd = {
  '@context': 'https://schema.org',
  '@type': 'NutritionInformation',
  servingSize: '100 g',
  calories: ni(kcal, 'kcal', 'value'),
  proteinContent: ni(protein, 'g', 'value'),
  fatContent: ni(fat, 'g', 'value'),
  carbohydrateContent: ni(carb, 'g', 'value'),
  fiberContent: ni(val('fiber'), 'g', 'value'),
  sugarContent: ni(val('sugars'), 'g', 'value'),
  sodiumContent: ni(val('sodium'), 'mg', 'value'),
};

const favName = encodeURIComponent(foodName);
---

<section class="food" data-slug={food.slug}>
  <nav class="crumbs" aria-label="breadcrumb">
    <a href={lang === 'ko' ? '/' : '/en'}>{s.home}</a>
    {food.category && <>› <a href={`${lang === 'ko' ? '/category' : '/en/category'}/${food.category.slug}`}>{lang === 'ko' ? (food.category.name_ko ?? food.category.name_en) : (food.category.name_en ?? food.category.name_ko)}</a></>}
    › <span>{foodName}</span>
  </nav>

  <h1>{food.emoji ?? '🍽️'} {foodName} {lang === 'ko' ? '칼로리 · 영양성분' : 'Calories & Nutrition'}</h1>

  <div class="food-actions">
    <button type="button" class="btn act-btn" id="fav-btn"
      data-slug={food.slug} data-name={foodName} data-emoji={food.emoji ?? '🍽️'} data-kcal={kcal ?? ''} data-ko={lang === 'ko' ? '1' : '0'}>
      <span class="fav-star">☆</span> <span class="fav-label">{lang === 'ko' ? '즐겨찾기' : 'Favorite'}</span>
    </button>
    <button type="button" class="btn act-btn" id="share-btn">
      <span aria-hidden="true">↗</span> {lang === 'ko' ? '공유' : 'Share'}
    </button>
    <div id="share-links" class="share-links" hidden>
      <a target="_blank" rel="noopener" data-share="x">𝕏</a>
      <a target="_blank" rel="noopener" data-share="fb">f</a>
      <a target="_blank" rel="noopener" data-share="naver">N</a>
      <button type="button" data-share="copy">{lang === 'ko' ? '링크 복사' : 'Copy link'}</button>
    </div>
  </div>

  {food.tags.length > 0 && (
    <ul class="tags">
      {food.tags.map((tg) => <li>{tagLabel[tg] ? tagLabel[tg][lang] : tg}</li>)}
    </ul>
  )}
  {desc && <p class="desc">{desc}</p>}

  <div class="hero">
    <div class="donut" style={`background: conic-gradient(var(--c-protein) 0% ${pPct}%, var(--c-fat) ${pPct}% ${pPct + fPct}%, var(--c-carb) ${pPct + fPct}% 100%)`}>
      <div class="donut-hole">
        <strong>{kcal ?? '—'}</strong>
        <span>kcal / 100g</span>
      </div>
    </div>
    <div class="macro-legend">
      <div><span class="dot" style={`background:var(--c-protein)`}></span>{s.protein} <b>{protein ?? '—'}g</b> · {pPct}%</div>
      <div><span class="dot" style={`background:var(--c-fat)`}></span>{s.fat} <b>{fat ?? '—'}g</b> · {fPct}%</div>
      <div><span class="dot" style={`background:var(--c-carb)`}></span>{s.carb} <b>{carb ?? '—'}g</b> · {cPct}%</div>
      <p class="muted">{s.macroRatio}</p>
    </div>
  </div>

  <h2>{s.nutritionFacts} <span class="muted">({s.per100g})</span></h2>
  <table class="nutri">
    <thead><tr><th>{lang === 'ko' ? '영양소' : 'Nutrient'}</th><th>{lang === 'ko' ? '함량' : 'Amount'} / 100g</th></tr></thead>
    <tbody>
      {rows.map((r) => (
        <tr><td>{r.label}</td><td>{r.value} {r.unit}</td></tr>
      ))}
    </tbody>
  </table>

  <AdSlot slot="food-mid" />

  <div class="calc">
    <h2>🔢 {s.servingCalc}</h2>
    <div class="calc-presets" role="group" aria-label="presets">
      <button type="button" class="preset-btn" data-set="50">50g</button>
      <button type="button" class="preset-btn" data-set="100">100g</button>
      <button type="button" class="preset-btn" data-set="150">150g</button>
      <button type="button" class="preset-btn" data-set="200">200g</button>
      <button type="button" class="preset-btn" data-set="300">300g</button>
    </div>
    <div class="calc-controls">
      <button type="button" class="btn step-btn" data-step="-25">−25</button>
      <button type="button" class="btn step-btn" data-step="-5" aria-label="-5g">−</button>
      <div class="calc-input">
        <input id="grams" type="number" min="0" step="1" value="100" inputmode="numeric" data-protein={protein ?? ''} data-fat={fat ?? ''} data-carb={carb ?? ''} data-kcal={kcal ?? ''} aria-label={s.grams} />
        <span>{s.grams}</span>
      </div>
      <button type="button" class="btn step-btn" data-step="5" aria-label="+5g">+</button>
      <button type="button" class="btn step-btn" data-step="25">+25</button>
    </div>
    <ul class="calc-out">
      <li class="calc-stat"><span class="cs-label">{s.kcal}</span><b id="out-kcal">{kcal ?? '—'}</b></li>
      <li class="calc-stat"><span class="cs-label">{s.protein}</span><b id="out-protein">{protein ?? '—'}g</b></li>
      <li class="calc-stat"><span class="cs-label">{s.fat}</span><b id="out-fat">{fat ?? '—'}g</b></li>
      <li class="calc-stat"><span class="cs-label">{s.carb}</span><b id="out-carb">{carb ?? '—'}g</b></li>
    </ul>
  </div>

  {food.related.length > 0 && (
    <div class="related">
      <h2>{s.relatedFoods}</h2>
      <ul>
        {food.related.map((r) => (
          <li><a href={`${pathPrefix}/${r.slug}`}>{r.emoji ?? '🍽️'} {(lang === 'ko' ? (r.name_ko ?? r.name_en) : (r.name_en ?? r.name_ko)) ?? r.slug}</a>{r.kcal != null && <span class="muted"> · {r.kcal} kcal</span>}</li>
        ))}
      </ul>
    </div>
  )}

  <details class="faq">
    <summary>FAQ</summary>
    {faqs.map((f) => (<div><h3>{f.q}</h3><p>{f.a}</p></div>))}
  </details>

  <p class="source muted">{s.source}: <a href={src.url} rel="nofollow">{src.name}</a></p>
  <p class="muted small">{s.disclaimer}</p>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
<script type="application/ld+json" set:html={JSON.stringify(nutritionLd)} />

<script>
  const input = document.getElementById('grams') as HTMLInputElement | null;
  if (input) {
    const k = Number(input.dataset.kcal || 0);
    const p = Number(input.dataset.protein || 0);
    const f = Number(input.dataset.fat || 0);
    const c = Number(input.dataset.carb || 0);
    const ok = document.getElementById('out-kcal')!;
    const op = document.getElementById('out-protein')!;
    const of = document.getElementById('out-fat')!;
    const oc = document.getElementById('out-carb')!;
    const r = (n: number) => Math.round(n * 100) / 100;
    const update = () => {
      const g = Math.max(0, Number(input.value) || 0);
      const m = g / 100;
      ok.textContent = r(k * m).toString();
      op.textContent = r(p * m) + 'g';
      of.textContent = r(f * m) + 'g';
      oc.textContent = r(c * m) + 'g';
    };
    input.addEventListener('input', update);
    document.querySelectorAll<HTMLButtonElement>('.step-btn').forEach((b) => {
      b.addEventListener('click', () => {
        input.value = String(Math.max(0, (Number(input.value) || 0) + Number(b.dataset.step)));
        update();
      });
    });
    document.querySelectorAll<HTMLButtonElement>('.preset-btn').forEach((b) => {
      b.addEventListener('click', () => { input.value = String(Number(b.dataset.set) || 0); update(); });
    });
  }

  // ---- Favorites (localStorage) ----
  const section = document.querySelector<HTMLElement>('.food');
  const favBtn = document.getElementById('fav-btn') as HTMLButtonElement | null;
  const readFavs = (): any[] => { try { return JSON.parse(localStorage.getItem('calorie-favs') || '[]'); } catch { return []; } };
  const writeFavs = (a: any[]) => { try { localStorage.setItem('calorie-favs', JSON.stringify(a.slice(0, 100))); } catch {} };
  const renderFav = () => {
    if (!favBtn || !section) return;
    const favs = readFavs();
    const on = favs.some((x) => x.slug === section.dataset.slug);
    favBtn.classList.toggle('on', on);
    const star = favBtn.querySelector('.fav-star');
    const label = favBtn.querySelector('.fav-label');
    const ko = favBtn.dataset.ko === '1';
    if (star) star.textContent = on ? '★' : '☆';
    if (label) label.textContent = on ? (ko ? '즐겨찾기됨' : 'Favorited') : (ko ? '즐겨찾기' : 'Favorite');
  };
  if (favBtn) {
    favBtn.addEventListener('click', () => {
      const favs = readFavs();
      const slug = favBtn.dataset.slug!;
      const idx = favs.findIndex((x) => x.slug === slug);
      if (idx >= 0) favs.splice(idx, 1);
      else favs.unshift({ slug, name: favBtn.dataset.name, emoji: favBtn.dataset.emoji, kcal: favBtn.dataset.kcal ? Number(favBtn.dataset.kcal) : null });
      writeFavs(favs);
      renderFav();
    });
    renderFav();
  }

  // ---- Recently viewed (localStorage, newest first, deduped, capped) ----
  if (section) {
    try {
      const slug = section.dataset.slug!;
      const rec: any[] = JSON.parse(localStorage.getItem('calorie-recent') || '[]');
      const filtered = rec.filter((x) => x.slug !== slug);
      filtered.unshift({ slug, name: favBtn?.dataset.name ?? slug, emoji: favBtn?.dataset.emoji ?? '🍽️', kcal: favBtn?.dataset.kcal ? Number(favBtn.dataset.kcal) : null });
      localStorage.setItem('calorie-recent', JSON.stringify(filtered.slice(0, 12)));
    } catch {}
  }

  // ---- Share ----
  const shareBtn = document.getElementById('share-btn');
  const shareLinks = document.getElementById('share-links');
  if (shareBtn && shareLinks) {
    const u = location.href;
    const ko = (document.documentElement.lang || 'ko').indexOf('ko') === 0;
    const shareUrl = (base: string) => base + encodeURIComponent(u);
    const setLink = (sel: string, base: string) => {
      const a = shareLinks.querySelector<HTMLAnchorElement>(`[data-share="${sel}"]`);
      if (a) a.href = shareUrl(base);
    };
    setLink('x', 'https://twitter.com/intent/tweet?url=');
    setLink('fb', 'https://www.facebook.com/sharer/sharer.php?u=');
    setLink('naver', 'https://share.naver.com/web/shareView?url=');
    shareBtn.addEventListener('click', async () => {
      const title = document.title;
      if (navigator.share) {
        try { await navigator.share({ title, url: u }); return; } catch {}
      }
      shareLinks.hidden = !shareLinks.hidden;
    });
    const copyBtn = shareLinks.querySelector<HTMLButtonElement>('[data-share="copy"]');
    if (copyBtn) copyBtn.addEventListener('click', async () => {
      try { await navigator.clipboard.writeText(u); copyBtn.textContent = ko ? '복사됨 ✓' : 'Copied ✓'; } catch {}
    });
  }
</script>

<style>
  .food { max-width: 760px; margin: 0 auto; }
  .crumbs { font-size: .85rem; color: var(--muted); margin-bottom: .5rem; }
  .crumbs a { color: var(--link); text-decoration: none; }
  h1 { font-size: 1.6rem; margin: .3rem 0; }
  .food-actions { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; margin: .4rem 0 .2rem; position: relative; }
  .act-btn { min-height: 40px; }
  .fav-star { color: var(--star); }
  .act-btn.on { border-color: var(--star); color: var(--star); }
  .share-links { display: inline-flex; align-items: center; gap: .35rem; background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: .25rem .35rem; box-shadow: var(--shadow); }
  .share-links a, .share-links button { display: inline-flex; align-items: center; justify-content: center; min-width: 34px; min-height: 34px; padding: 0 .5rem; border-radius: 8px; font-weight: 700; border: 1px solid var(--border); background: var(--card); color: var(--text); font-family: inherit; font-size: .9rem; cursor: pointer; text-decoration: none; }
  .tags { list-style: none; padding: 0; display: flex; gap: .4rem; flex-wrap: wrap; margin: .5rem 0; }
  .tags li { background: var(--tag-bg); color: var(--tag-text); font-size: .75rem; padding: .2rem .6rem; border-radius: 999px; }
  .desc { color: var(--prose); margin: 1rem 0; }
  .hero { display: flex; gap: 2rem; align-items: center; margin: 1.5rem 0; flex-wrap: wrap; }
  .donut { width: 150px; height: 150px; border-radius: 50%; display: grid; place-items: center; flex-shrink: 0; }
  .donut-hole { width: 100px; height: 100px; background: var(--card); border-radius: 50%; display: grid; place-items: center; text-align: center; }
  .donut-hole strong { font-size: 1.5rem; }
  .donut-hole span { font-size: .7rem; color: var(--muted); }
  .macro-legend div { margin: .25rem 0; }
  .dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: .4rem; }
  .muted { color: var(--muted); font-size: .85rem; }
  table.nutri { width: 100%; border-collapse: collapse; margin: 1rem 0; }
  table.nutri th, table.nutri td { padding: .5rem .6rem; border-bottom: 1px solid var(--row-border); text-align: left; }
  table.nutri th { background: var(--th-bg); font-size: .85rem; }
  .calc { background: var(--calc-bg); border: 1px solid var(--border); border-radius: 14px; padding: 1rem 1.2rem; margin: 1.5rem 0; }
  .calc-presets { display: flex; gap: .35rem; flex-wrap: wrap; margin-bottom: .75rem; }
  .preset-btn { min-height: 36px; padding: 0 .7rem; border: 1px solid var(--border); border-radius: 9px; background: var(--card); color: var(--text); font-weight: 600; font-size: .88rem; cursor: pointer; -webkit-tap-highlight-color: transparent; font-family: inherit; }
  .preset-btn:hover { border-color: var(--primary); color: var(--primary-dark); }
  .calc-controls { display: flex; align-items: center; gap: .4rem; flex-wrap: wrap; }
  .calc-input { display: inline-flex; align-items: center; gap: .4rem; }
  .calc-input input { width: 84px; min-height: 44px; padding: .4rem .5rem; text-align: center; border: 1px solid var(--border); border-radius: 10px; font-size: 1.15rem; font-weight: 700; background: var(--input-bg); color: var(--text); }
  .calc-input span { color: var(--muted); font-size: .9rem; }
  .step-btn { min-width: 44px; padding: 0 .55rem; font-weight: 700; }
  .calc-out { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: .6rem; margin-top: 1rem; }
  .calc-stat { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: .55rem .8rem; display: flex; flex-direction: column; }
  .cs-label { color: var(--muted); font-size: .76rem; }
  .calc-stat b { font-size: 1.15rem; color: var(--primary-dark); }
  .related ul { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: .5rem; }
  .related li { padding: .4rem 0; }
  .faq { margin: 1.5rem 0; }
  .faq summary { cursor: pointer; font-weight: 600; }
  .source { margin-top: 2rem; }
  .small { font-size: .8rem; }
  @media (max-width: 600px) {
    .hero { flex-direction: column; text-align: center; gap: 1rem; }
    .donut { width: 128px; height: 128px; }
    .donut-hole { width: 86px; height: 86px; }
    .donut-hole strong { font-size: 1.3rem; }
    .macro-legend div { font-size: .95rem; }
    table.nutri th, table.nutri td { padding: .45rem .35rem; font-size: .92rem; }
    .related ul { grid-template-columns: 1fr; }
    .calc { padding: .9rem; }
  }
</style>
