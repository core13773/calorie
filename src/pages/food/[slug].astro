---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FoodDetailPage from '../../components/FoodDetailPage.astro';
import { getFoodSlugs, getFoodDetail } from '../../lib/db';

export async function getStaticPaths() {
  const slugs = await getFoodSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const food = await getFoodDetail(slug!);
if (!food) return new Response(null, { status: 404 });

const foodName = food.name_ko ?? food.name_en ?? food.slug;
const kcal = food.nutrients.find((n) => n.nutrient_id === 'energy')?.amount;
const title = `${foodName} 칼로리 · 영양성분 (100g당) | calorie.monster`;
const description = food.desc_ko ?? food.desc_en ?? `${foodName}의 칼로리와 영양성분(단백질, 지방, 탄수화물 등)을 100g 기준으로 확인하세요. USDA 식품영양성분 데이터.`;
---
<BaseLayout title={title} description={description} lang="ko" canonicalPath={`/food/${food.slug}`}>
  <FoodDetailPage food={food} lang="ko" />
</BaseLayout>
