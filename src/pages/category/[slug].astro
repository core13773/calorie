---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCategories, getCategoryBySlug } from '../../lib/db';

export async function getStaticPaths() {
  const cats = await getCategories();
  return cats.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const data = await getCategoryBySlug(slug!);
if (!data) return new Response(null, { status: 404 });
const { category, foods } = data;
const name = category.name_ko ?? category.name_en ?? category.slug;
const title = `${name} 칼로리 · 영양성분 목록 | calorie.monster`;
const desc = `${name} 카테고리 식품 ${category.count}종의 칼로리와 영양성분(100g 기준). USDA 식품영양성분 데이터.`;
---
<BaseLayout title={title} description={desc} lang="ko" canonicalPath={`/category/${category.slug}`}>
  <nav class="crumbs"><a href="/category">카테고리</a> › <span>{name}</span></nav>
  <h1>{name} <span class="muted">({category.count}종)</span></h1>
  <ul class="foodgrid">
    {foods.map((f) => (
      <li><a href={`/food/${f.slug}`}>{f.name_ko ?? f.name_en ?? f.slug}</a>{f.kcal != null && <span class="muted"> {f.kcal} kcal</span>}</li>
    ))}
  </ul>
</BaseLayout>
<style>
  .crumbs { font-size: .85rem; color: #888; }
  .foodgrid { list-style: none; padding: 0; columns: 2; column-gap: 2rem; }
  .foodgrid li { padding: .3rem 0; break-inside: avoid; }
  @media (max-width: 600px) { .foodgrid { columns: 1; } }
</style>
