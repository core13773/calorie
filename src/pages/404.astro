---
import BaseLayout from '../layouts/BaseLayout.astro';
// Detect locale from the missing path so the 404 page speaks the right language.
const path = Astro.url.pathname;
const lang: 'ko' | 'en' = path.startsWith('/en') ? 'en' : 'ko';
const title = lang === 'ko' ? '페이지를 찾을 수 없습니다 | calorie.monster' : 'Page not found | calorie.monster';
const home = lang === 'ko' ? '/' : '/en';
---
<BaseLayout title={title} lang={lang} canonicalPath={path}>
  <section class="notfound">
    <div class="nf-emoji">🔍</div>
    <h1>{lang === 'ko' ? '404 — 페이지를 찾을 수 없어요' : '404 — Page not found'}</h1>
    <p class="muted">{lang === 'ko' ? '주소가 변경되었거나 존재하지 않는 페이지입니다.' : 'The address may have changed or the page does not exist.'}</p>
    <p class="nf-actions">
      <a class="btn btn-primary" href={home}>{lang === 'ko' ? '🏠 홈으로' : '🏠 Home'}</a>
      <a class="btn" href={lang === 'ko' ? '/search' : '/en/search'}>{lang === 'ko' ? '🔍 식품 검색' : '🔍 Search foods'}</a>
    </p>
  </section>
</BaseLayout>
<style>
  .notfound { text-align: center; padding: 3rem 1rem 5rem; }
  .nf-emoji { font-size: 3.5rem; margin-bottom: .5rem; }
  .notfound h1 { font-size: 1.6rem; }
  .nf-actions { display: flex; gap: .6rem; justify-content: center; flex-wrap: wrap; margin-top: 1.5rem; }
</style>
