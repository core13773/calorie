---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { strings } from '../../i18n/ui';
const s = strings.en;
const q = Astro.url.searchParams.get('q') ?? '';
---
<BaseLayout title="Food Search | calorie.monster" description="Search calories and nutrition facts by food name. 7,000+ foods from USDA FoodData Central." lang="en" canonicalPath="/en/search">
  <h1>Food Search</h1>
  <input id="q" type="search" data-prefix="/en/food/" placeholder={s.searchPlaceholder} value={q} autocomplete="off" aria-label={s.search} />
  <p id="status" class="muted"></p>
  <ul id="results" class="foodgrid"></ul>
</BaseLayout>
<script src="/js/search.js" defer></script>
<style>
  #q { width: 100%; padding: .7rem .9rem; border: 1px solid #ccc; border-radius: 8px; font-size: 1rem; margin-bottom: 1rem; }
  .foodgrid { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(260px,1fr)); gap: .3rem; }
</style>
