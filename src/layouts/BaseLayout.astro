---
import { SITE_NAME, SITE_URL } from '../consts';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'ko' | 'en';
  canonicalPath?: string;
}

const { title, description = '식품 영양성분과 칼로리를 검색하세요. USDA + 식약처 데이터 기반.', lang = 'ko', canonicalPath = '', enAvailable = true } = Astro.props;
const cp = canonicalPath || Astro.url.pathname;
const canonical = new URL(cp, SITE_URL).href;
const isEn = cp.startsWith('/en');
const koPath = isEn ? (cp.slice(3) || '/') : cp;
const enPath = isEn ? cp : '/en' + (cp === '/' ? '' : cp);
const koUrl = new URL(koPath, SITE_URL).href;
const enUrl = new URL(enPath, SITE_URL).href;
// Language toggle: go to the equivalent page in the other language. Korean-only
// pages (식약처 foods, no English version) fall back to the English homepage.
const toggleHref = isEn ? koPath : (enAvailable ? enPath : '/en');
const showEn = isEn || enAvailable;
const home = lang === 'ko' ? '/' : '/en';
const navItems = [
  { href: home, icon: '🏠', label: lang === 'ko' ? '홈' : 'Home' },
  { href: lang === 'ko' ? '/category' : '/en/category', icon: '📂', label: lang === 'ko' ? '카테고리' : 'Categories' },
  { href: lang === 'ko' ? '/ranking' : '/en/ranking', icon: '🏆', label: lang === 'ko' ? '랭킹' : 'Rankings' },
  { href: lang === 'ko' ? '/search' : '/en/search', icon: '🔍', label: lang === 'ko' ? '검색' : 'Search' },
];
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#16a34a" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ko" href={koUrl} />
    {showEn && <link rel="alternate" hreflang="en" href={enUrl} />}
    <link rel="alternate" hreflang="x-default" href={koUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === 'ko' ? 'ko_KR' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    {import.meta.env.PUBLIC_ADSENSE_CLIENT && (
      <script is:inline async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${import.meta.env.PUBLIC_ADSENSE_CLIENT}`} crossorigin="anonymous"></script>
    )}
  </head>
  <body>
    <a class="skip" href="#main">{lang === 'ko' ? '본문으로 건너뛰기' : 'Skip to content'}</a>
    <header class="site-header">
      <div class="container hdr-inner">
        <a class="brand" href={home}><span class="brand-icon">🥗</span> {SITE_NAME}</a>
        <nav class="main-nav" aria-label="Primary">
          {navItems.map((n) => (
            <a href={n.href}><span class="ni">{n.icon}</span><span class="nl">{n.label}</span></a>
          ))}
          <a class="lang-toggle" href={toggleHref} aria-label="language">{isEn ? '한국어' : 'EN'}</a>
        </nav>
      </div>
    </header>
    <main id="main">
      <div class="container main-inner">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} {SITE_NAME} · {lang === 'ko' ? '데이터: USDA FoodData Central + 식약처 식품영양성분DB' : 'Data: USDA FoodData Central + 식약처 nutrition DB'}</p>
        <p class="footlinks">
          <a href={lang === 'ko' ? '/about' : '/en/about'}>{lang === 'ko' ? '소개' : 'About'}</a> ·
          <a href={lang === 'ko' ? '/privacy' : '/en/privacy'}>{lang === 'ko' ? '개인정보처리방침' : 'Privacy'}</a> ·
          <a href={lang === 'ko' ? '/contact' : '/en/contact'}>{lang === 'ko' ? '문의' : 'Contact'}</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  .skip { position: absolute; left: -9999px; top: 0; }
  .skip:focus { left: 1rem; top: 1rem; background: #fff; padding: .5rem 1rem; border-radius: 8px; z-index: 100; box-shadow: var(--shadow); }
  .site-header { position: sticky; top: 0; background: rgba(255, 255, 255, .9); backdrop-filter: saturate(180%) blur(10px); -webkit-backdrop-filter: saturate(180%) blur(10px); border-bottom: 1px solid var(--border); z-index: 50; }
  .hdr-inner { display: flex; align-items: center; justify-content: space-between; gap: .5rem; min-height: 58px; padding: .35rem 1rem; }
  .brand { display: inline-flex; align-items: center; gap: .4rem; font-weight: 800; font-size: 1.15rem; color: var(--primary-dark); white-space: nowrap; }
  .brand:hover { text-decoration: none; }
  .brand-icon { font-size: 1.35rem; }
  .main-nav { display: flex; align-items: center; gap: .15rem; overflow-x: auto; }
  .main-nav::-webkit-scrollbar { display: none; }
  .main-nav a { display: inline-flex; align-items: center; gap: .35rem; padding: .5rem .6rem; border-radius: 10px; color: var(--text); font-size: .92rem; font-weight: 600; white-space: nowrap; }
  .main-nav a:hover { background: var(--primary-soft); color: var(--primary-dark); text-decoration: none; }
  .ni { font-size: 1.05rem; }
  .lang-toggle { margin-left: .2rem; border: 1px solid var(--border); }
  .main-inner { padding: 1.5rem 1rem 3rem; }
  .site-footer { border-top: 1px solid var(--border); background: #fff; color: var(--muted); font-size: .85rem; }
  .site-footer .container { padding: 1.4rem 1rem; }
  .footlinks { margin-top: .3rem; }
  .footlinks a { color: var(--muted); }
  @media (max-width: 560px) {
    .nl { display: none; }
    .main-nav a { padding: .5rem .55rem; }
    .brand { font-size: 1.05rem; }
  }
</style>
