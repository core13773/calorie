---
import { SITE_NAME, SITE_URL, GA4_ID } from '../consts';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'ko' | 'en';
  canonicalPath?: string;
  enAvailable?: boolean;
  koAvailable?: boolean;
}

const { title, description = '식품 영양성분과 칼로리를 검색하세요. USDA + 식약처 데이터 기반.', lang = 'ko', canonicalPath = '', enAvailable = true, koAvailable = true } = Astro.props;
const cp = canonicalPath || Astro.url.pathname;
const canonical = new URL(cp, SITE_URL).href;
const isEn = cp.startsWith('/en');
const koPath = isEn ? (cp.slice(3) || '/') : cp;
const enPath = isEn ? cp : '/en' + (cp === '/' ? '' : cp);
const koUrl = new URL(koPath, SITE_URL).href;
const enUrl = new URL(enPath, SITE_URL).href;
// Language toggle: go to the equivalent page in the other language. Korean-only
// pages (식약처 foods, no English version) fall back to the English homepage.
const toggleHref = isEn ? (koAvailable ? koPath : '/') : (enAvailable ? enPath : '/en');
const hasKo = !isEn || koAvailable;
const hasEn = isEn || enAvailable;
const home = lang === 'ko' ? '/' : '/en';
const navItems = [
  { href: home, icon: '🏠', label: lang === 'ko' ? '홈' : 'Home', match: (p: string) => p === home },
  { href: lang === 'ko' ? '/category' : '/en/category', icon: '📂', label: lang === 'ko' ? '카테고리' : 'Categories', match: (p: string) => p.includes('/category') },
  { href: lang === 'ko' ? '/ranking' : '/en/ranking', icon: '🏆', label: lang === 'ko' ? '랭킹' : 'Rankings', match: (p: string) => p.includes('/ranking') },
  { href: lang === 'ko' ? '/search' : '/en/search', icon: '🔍', label: lang === 'ko' ? '검색' : 'Search', match: (p: string) => p.includes('/search') },
];
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="naver-site-verification" content="67981deb4822eeef38c4ebd2cfd4edc94a1d66ca" />
    <meta name="google-site-verification" content="dCmQcE5V4qasa--zavVwRUu8aPXDAQMoNvNa2DXU8Jc" />
    <meta name="969c2167d4916413af9fa3919d72231aef85df23" content="969c2167d4916413af9fa3919d72231aef85df23" />
    <script is:inline data-cfasync="false" type="text/javascript" src="https://pleased-report.com/b/3vV.0VPs3/paveb/muVeJHZxDM0/3iMvTkgewqMbzeQ/1eLbT/c-xtOHD/A/zqN/DdkK"></script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#16a34a" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f1a16" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonical} />
    {hasKo && <link rel="alternate" hreflang="ko" href={koUrl} />}
    {hasEn && <link rel="alternate" hreflang="en" href={enUrl} />}
    <link rel="alternate" hreflang="x-default" href={hasKo ? koUrl : enUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${SITE_URL}/og.svg`} />
    <meta property="og:locale" content={lang === 'ko' ? 'ko_KR' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${SITE_URL}/og.svg`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    {import.meta.env.PUBLIC_ADSENSE_CLIENT && (
      <script is:inline async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${import.meta.env.PUBLIC_ADSENSE_CLIENT}`} crossorigin="anonymous"></script>
    )}
    {GA4_ID && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
        <script is:inline define:vars={{ ga4: GA4_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', ga4);
        </script>
      </>
    )}
    <script is:inline>
      (function () {
        if (location.pathname !== '/') return;
        try {
          if (localStorage.getItem('calorie-lang')) return;
          var L = (navigator.languages && navigator.languages.length ? navigator.languages : [navigator.language || '']);
          var k = L.some(function (l) { return (l || '').toLowerCase().indexOf('ko') === 0; });
          if (!k) location.replace('/en' + location.search + location.hash);
        } catch (e) {}
      })();
    </script>
    {/* Apply saved/system theme before first paint to avoid a flash. */}
    <script is:inline>
      (function () {
        try {
          var s = localStorage.getItem('calorie-theme');
          var dark = s ? s === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
          if (dark) document.documentElement.setAttribute('data-theme', 'dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip" href="#main">{lang === 'ko' ? '본문으로 건너뛰기' : 'Skip to content'}</a>
    <header class="site-header">
      <div class="container hdr-inner">
        <a class="brand" href={home}><span class="brand-icon">🥗</span> {SITE_NAME}</a>
        <div class="hdr-right">
          <nav class="main-nav" aria-label="Primary">
            {navItems.map((n) => (
              <a href={n.href} aria-current={n.match(cp) ? 'page' : undefined}><span class="ni">{n.icon}</span><span class="nl">{n.label}</span></a>
            ))}
          </nav>
          <div class="hdr-actions">
            <a class="lang-toggle" href={toggleHref} aria-label="language" data-lang-toggle>{isEn ? '한국어' : 'EN'}</a>
            <button type="button" class="theme-toggle" aria-label={lang === 'ko' ? '다크 모드 전환' : 'Toggle dark mode'} data-theme-toggle>
              <span class="theme-i theme-sun">☀️</span><span class="theme-i theme-moon">🌙</span>
            </button>
          </div>
        </div>
      </div>
    </header>
    <main id="main">
      <div class="container main-inner">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} {SITE_NAME} · {lang === 'ko' ? '데이터: USDA FoodData Central + 식약처 식품영양성분DB' : 'Data: USDA FoodData Central + 식약처 nutrition DB'}</p>
        <p class="footlinks">
          <a href={lang === 'ko' ? '/about' : '/en/about'}>{lang === 'ko' ? '소개' : 'About'}</a> ·
          <a href={lang === 'ko' ? '/privacy' : '/en/privacy'}>{lang === 'ko' ? '개인정보처리방침' : 'Privacy'}</a> ·
          <a href={lang === 'ko' ? '/contact' : '/en/contact'}>{lang === 'ko' ? '문의' : 'Contact'}</a>
        </p>
      </div>
    </footer>

    {/* Mobile bottom tab bar — app-style navigation */}
    <nav class="bottom-nav" aria-label={lang === 'ko' ? '모바일 메뉴' : 'Mobile'}>
      {navItems.map((n) => (
        <a href={n.href} class={n.match(cp) ? 'active' : ''} aria-current={n.match(cp) ? 'page' : undefined}>
          <span class="bn-icon">{n.icon}</span><span class="bn-label">{n.label}</span>
        </a>
      ))}
    </nav>

    <script is:inline>
      // Language toggle: remember explicit choice so the auto-redirect respects it.
      var lt = document.querySelectorAll('[data-lang-toggle], .lang-toggle-mob');
      lt.forEach(function (el) { el.addEventListener('click', function () { try { localStorage.setItem('calorie-lang', '1'); } catch (e) {} }); });
      // Theme toggle: persist + apply. Falls through to system pref when not set.
      var tt = document.querySelector('[data-theme-toggle]');
      if (tt) tt.addEventListener('click', function () {
        var dark = document.documentElement.getAttribute('data-theme') === 'dark';
        if (dark) { document.documentElement.removeAttribute('data-theme'); try { localStorage.setItem('calorie-theme', 'light'); } catch (e) {} }
        else { document.documentElement.setAttribute('data-theme', 'dark'); try { localStorage.setItem('calorie-theme', 'dark'); } catch (e) {} }
      });
      // Register the service worker for offline support.
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () { navigator.serviceWorker.register('/sw.js').catch(function () {}); });
      }
    </script>
  </body>
</html>

<style>
  .skip { position: absolute; left: -9999px; top: 0; }
  .skip:focus { left: 1rem; top: 1rem; background: var(--card); padding: .5rem 1rem; border-radius: 8px; z-index: 100; box-shadow: var(--shadow); }
  .site-header { position: sticky; top: 0; padding-top: env(safe-area-inset-top); background: var(--header-bg); backdrop-filter: saturate(180%) blur(10px); -webkit-backdrop-filter: saturate(180%) blur(10px); border-bottom: 1px solid var(--border); z-index: 50; }
  .hdr-inner { display: flex; align-items: center; justify-content: space-between; gap: .5rem; min-height: 58px; padding: .35rem 1rem; padding-left: max(1rem, env(safe-area-inset-left)); padding-right: max(1rem, env(safe-area-inset-right)); }
  .brand { display: inline-flex; align-items: center; gap: .4rem; font-weight: 800; font-size: 1.15rem; color: var(--primary-dark); white-space: nowrap; }
  .brand:hover { text-decoration: none; }
  .brand-icon { font-size: 1.35rem; }
  .hdr-right { display: flex; align-items: center; gap: .5rem; }
  .main-nav { display: flex; align-items: center; gap: .15rem; overflow-x: auto; }
  .main-nav::-webkit-scrollbar { display: none; }
  .main-nav a { display: inline-flex; align-items: center; gap: .35rem; padding: .5rem .6rem; border-radius: 10px; color: var(--text); font-size: .92rem; font-weight: 600; white-space: nowrap; }
  .main-nav a:hover { background: var(--primary-soft); color: var(--primary-dark); text-decoration: none; }
  .main-nav a[aria-current="page"] { color: var(--primary-dark); }
  .ni { font-size: 1.05rem; }
  .hdr-actions { display: flex; align-items: center; gap: .35rem; }
  .lang-toggle { display: inline-flex; align-items: center; min-height: 40px; padding: 0 .7rem; border-radius: 10px; border: 1px solid var(--border); background: var(--card); color: var(--text); font-weight: 600; font-size: .88rem; -webkit-tap-highlight-color: transparent; }
  .theme-toggle { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 10px; border: 1px solid var(--border); background: var(--card); color: var(--text); cursor: pointer; -webkit-tap-highlight-color: transparent; }
  .theme-i { font-size: 1.05rem; line-height: 1; }
  :global(html[data-theme='dark']) .theme-sun { display: inline; }
  :global(html[data-theme='dark']) .theme-moon { display: none; }
  .theme-sun { display: none; }
  .theme-moon { display: inline; }
  .main-inner { padding: 1.5rem 1rem 3rem; }
  .site-footer { border-top: 1px solid var(--border); background: var(--footer-bg); color: var(--muted); font-size: .85rem; padding-bottom: env(safe-area-inset-bottom); }
  .site-footer .container { padding: 1.4rem 1rem; }
  .footlinks { margin-top: .3rem; }
  .footlinks a { color: var(--muted); }

  /* Bottom tab bar — mobile only */
  .bottom-nav { display: none; }

  @media (max-width: 768px) {
    .main-nav { display: none; }
    .hdr-actions { display: flex; }
    .bottom-nav {
      display: flex; position: fixed; bottom: 0; left: 0; right: 0; z-index: 60;
      background: var(--nav-bg); backdrop-filter: saturate(180%) blur(12px); -webkit-backdrop-filter: saturate(180%) blur(12px);
      border-top: 1px solid var(--border);
      padding-bottom: env(safe-area-inset-bottom);
    }
    .bottom-nav a {
      flex: 1; display: flex; flex-direction: column; align-items: center; gap: 2px;
      padding: .45rem 0 .35rem; color: var(--muted); font-size: .68rem; font-weight: 600;
      text-decoration: none; -webkit-tap-highlight-color: transparent;
    }
    .bottom-nav a.active { color: var(--primary-dark); }
    .bottom-nav .bn-icon { font-size: 1.25rem; line-height: 1; }
    /* keep content clear of the fixed bar */
    .main-inner { padding-bottom: calc(4.5rem + env(safe-area-inset-bottom)); }
    .site-footer { padding-bottom: calc(3rem + env(safe-area-inset-bottom)); }
  }
  @media (max-width: 560px) {
    .nl { display: none; }
    .brand { font-size: 1.05rem; }
  }
</style>
